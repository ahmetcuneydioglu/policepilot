{
  "expo": {
    "name": "SigortaOS",
    "slug": "mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "mobile",
    "userInterfaceStyle": "light",
    "ios": {
      "bundleIdentifier": "com.canahmettt.policepilot",
      "appleTeamId": "3U4QPG9Q82",
      "buildNumber": "2",
      "infoPlist": {
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#101A3C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "monochromeImage": "./assets/images/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.canahmettt.policepilot"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-image-picker",
        {
          "photosPermission": "SigortaOS müşteri evrakları için fotoğraf galerinize erişmek istiyor.",
          "cameraPermission": "SigortaOS evrak fotoğrafı çekmek için kameraya erişmek istiyor."
        }
      ],
      "expo-document-picker",
      [
        "expo-splash-screen",
        {
          "backgroundColor": "#0E1836",
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 150,
          "android": {
            "image": "./assets/images/splash-icon.png",
            "imageWidth": 150
          }
        }
      ],
      "expo-sharing",
      "./plugins/withoutPushEntitlement"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "router": {
      "root": "src/app"
    }
  }
}
